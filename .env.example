# Resend API key for the contact form (https://resend.com)
# When unset, contact form submissions are logged but not delivered.
RESEND_API_KEY=

# Email address that contact form messages should be delivered to.
# This is the inbox you'll receive messages in (e.g. your Google Workspace address).
CONTACT_TO_EMAIL=

# (Optional) Verified "from" address. Defaults to Resend's onboarding sender.
# Once your domain is verified in Resend, set this to e.g.
#   "Cajun Collectibles <noreply@cajuncollectibles.com>"
CONTACT_FROM_EMAIL=
